def cmd_temp(args):
    ip = get_ip(args)
    temp = float(args.temp)
    if temp < 15 or temp > 30:
        print("Temperature must be between 15.0 and 30.0", file=sys.stderr)
        sys.exit(1)
    setpoint = int(temp * 100)
    result = send_command(ip, {"SysSetpoint": setpoint})
    print(f"Temperature set to {temp}C ({result})")


def cmd_zone(args):
    ip = get_ip(args)
    index = args.zone

    if args.zone_mode:
        zmode = args.zone_mode.lower()
        if zmode not in ZONE_MODES:
            print(f"Invalid zone mode. Choose from: {', '.join(ZONE_MODES.keys())}", file=sys.stderr)
            sys.exit(1)
        result = send_command(ip, {"ZoneMode": {"Index": index, "Mode": ZONE_MODES[zmode]}})
        print(f"Zone {index} mode set to {zmode} ({result})")

    if args.zone_temp is not None:
        temp = float(args.zone_temp)
        if temp < 15 or temp > 30:
            print("Temperature must be between 15.0 and 30.0", file=sys.stderr)
            sys.exit(1)
        setpoint = int(temp * 100)
        # Round to nearest 50 (0.5C increments)
        setpoint = round(setpoint / 50) * 50
        result = send_command(ip, {"ZoneSetpoint": {"Index": index, "Setpoint": setpoint}})
        print(f"Zone {index} temperature set to {setpoint / 100:.1f}C ({result})")

    if args.max_air is not None:
        air = int(args.max_air)
        air = max(0, min(100, round(air / 5) * 5))
        result = send_command(ip, {"ZoneMaxAir": {"Index": index, "MaxAir": air}})
        print(f"Zone {index} max airflow set to {air}% ({result})")

    if args.min_air is not None:
        air = int(args.min_air)
        air = max(0, min(100, round(air / 5) * 5))
        result = send_command(ip, {"ZoneMinAir": {"Index": index, "MinAir": air}})
        print(f"Zone {index} min airflow set to {air}% ({result})")

    if not any([args.zone_mode, args.zone_temp is not None, args.max_air is not None, args.min_air is not None]):
        # Just show zone info
        zdata = query_zone(ip, index)
        z = zdata.get("ZonesV2", zdata)
        zmode = ZONE_MODES_REV.get(z["Mode"], str(z["Mode"]))
        print(f"Zone {index}: {z['Name']}")
        print(f"  Temp:     {fmt_temp(z['Temp'])}")
        print(f"  Setpoint: {fmt_temp(z['Setpoint'])}")
        print(f"  Mode:     {zmode}")
        print(f"  Max Air:  {z['MaxAir']}%")
        print(f"  Min Air:  {z['MinAir']}%")


DEFAULTS_FILE = None


def get_defaults_path():
    import os
    return os.path.expanduser("~/.config/izone/defaults.json")


def cmd_defaults_save(args):
    import os
    ip = get_ip(args)
    data = query_system(ip)
    s = data["SystemV2"]
    num_zones = s["NoOfZones"]

    defaults = {
        "mode": s["SysMode"],
        "fan": s["SysFan"],
        "setpoint": s["Setpoint"],
        "zones": [],
    }
    for i in range(num_zones):
        zdata = query_zone(ip, i)
        z = zdata.get("ZonesV2", zdata)
        defaults["zones"].append({
            "index": i,
            "name": z["Name"],
            "mode": z["Mode"],
            "setpoint": z["Setpoint"],
            "max_air": z["MaxAir"],
            "min_air": z["MinAir"],
        })

    path = get_defaults_path()
    os.makedirs(os.path.dirname(path), exist_ok=True)
    with open(path, "w") as f:
        json.dump(defaults, f, indent=2)

    mode = MODES_REV.get(defaults["mode"], str(defaults["mode"]))
    fan = FAN_REV.get(defaults["fan"], str(defaults["fan"]))
    print(f"Defaults saved to {path}")
    print(f"  Mode: {mode}, Fan: {fan}, Temp: {fmt_temp(defaults['setpoint'])}")
    print(f"  Zones: {len(defaults['zones'])}")


def cmd_defaults_restore(args):
    import os
    path = get_defaults_path()
    if not os.path.exists(path):
        print("No saved defaults found. Run 'izone defaults save' first.", file=sys.stderr)
        sys.exit(1)

    with open(path) as f:
        defaults = json.load(f)

    ip = get_ip(args)
    import time

    send_command(ip, {"SysMode": defaults["mode"]})
    time.sleep(0.2)
    send_command(ip, {"SysFan": defaults["fan"]})
    time.sleep(0.2)
    send_command(ip, {"SysSetpoint": defaults["setpoint"]})

    for z in defaults["zones"]:
        time.sleep(0.2)
        send_command(ip, {"ZoneMode": {"Index": z["index"], "Mode": z["mode"]}})
        send_command(ip, {"ZoneSetpoint": {"Index": z["index"], "Setpoint": z["setpoint"]}})
        send_command(ip, {"ZoneMaxAir": {"Index": z["index"], "MaxAir": z["max_air"]}})
        send_command(ip, {"ZoneMinAir": {"Index": z["index"], "MinAir": z["min_air"]}})

    mode = MODES_REV.get(defaults["mode"], str(defaults["mode"]))
    fan = FAN_REV.get(defaults["fan"], str(defaults["fan"]))
    print(f"Defaults restored: mode={mode}, fan={fan}, temp={fmt_temp(defaults['setpoint'])}")
    print(f"  {len(defaults['zones'])} zones restored")


def cmd_defaults_show(args):
    import os
    path = get_defaults_path()
    if not os.path.exists(path):
        print("No saved defaults found. Run 'izone defaults save' first.", file=sys.stderr)
        sys.exit(1)

    with open(path) as f:
        defaults = json.load(f)

    mode = MODES_REV.get(defaults["mode"], str(defaults["mode"]))
    fan = FAN_REV.get(defaults["fan"], str(defaults["fan"]))
    print(f"Saved defaults ({path}):")
    print(f"  Mode:     {mode}")
    print(f"  Fan:      {fan}")
    print(f"  Setpoint: {fmt_temp(defaults['setpoint'])}")
    print()
    print(f"  {'#':<3} {'Name':<12} {'Set':>6} {'Mode':<10} {'Air%':>5}")
    print(f"  {'-' * 40}")
    for z in defaults["zones"]:
        zmode = ZONE_MODES_REV.get(z["mode"], str(z["mode"]))
