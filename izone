        cmd_profile_show(args)
    elif action == "delete":
        cmd_profile_delete(args)
    else:
        print("Usage: izone profile {save|apply|set|show|delete} <name>", file=sys.stderr)
        sys.exit(1)


def cmd_profile_save(args):
    """Save current live settings as a named profile."""
    name = args.name
    if not name:
        print("Profile name required.", file=sys.stderr)
        sys.exit(1)

    ip = get_ip(args)
    data = query_system(ip)
    s = data["SystemV2"]
    num_zones = s["NoOfZones"]

    profile = {
        "mode": MODES_REV.get(s["SysMode"], str(s["SysMode"])),
        "fan": FAN_REV.get(s["SysFan"], str(s["SysFan"])),
        "temp": s["Setpoint"],
        "close_others": True,
        "zones": {},
    }
    for i in range(num_zones):
        zdata = query_zone(ip, i)
        z = zdata.get("ZonesV2", zdata)
        profile["zones"][str(i)] = {
            "mode": z["Mode"],
            "temp": z["Setpoint"],
        }

    profiles = load_profiles()
    profiles[name] = profile
    save_profiles_file(profiles)
    print(f"Profile '{name}' saved (mode={profile['mode']}, fan={profile['fan']}, temp={fmt_temp(profile['temp'])}, {len(profile['zones'])} zones)")


def cmd_profile_apply(args):
    """Apply a named profile to the AC system."""
    import time as _time
    name = args.name
    if not name:
        print("Profile name required.", file=sys.stderr)
        sys.exit(1)

    profiles = load_profiles()
    if name not in profiles:
        print(f"Profile '{name}' not found. Run 'izone profiles' to list.", file=sys.stderr)
        sys.exit(1)

    profile = profiles[name]
    ip = get_ip(args)

    # Turn on
    send_command(ip, {"SysOn": 1})
    _time.sleep(0.2)

    # Set mode
    if "mode" in profile:
        try:
            mode_value = mode_to_value(profile["mode"])
        except ValueError as e:
            print(f"Profile '{name}' has invalid mode value: {e}", file=sys.stderr)
            sys.exit(1)
        send_command(ip, {"SysMode": mode_value})
        _time.sleep(0.2)

    # Set fan
    if "fan" in profile:
        try:
            fan_value = fan_to_value(profile["fan"])
        except ValueError as e:
            print(f"Profile '{name}' has invalid fan value: {e}", file=sys.stderr)
            sys.exit(1)
        send_command(ip, {"SysFan": fan_value})
        _time.sleep(0.2)

    # Set system temp
    if "temp" in profile:
        send_command(ip, {"SysSetpoint": profile["temp"]})
        _time.sleep(0.2)

    # Configure zones
    active_zone_indexes = set(profile.get("zones", {}).keys())
    sys_data = query_system(ip)
    num_zones = sys_data["SystemV2"]["NoOfZones"]

    for i in range(num_zones):
        si = str(i)
        if si in profile.get("zones", {}):
            zconf = profile["zones"][si]
            send_command(ip, {"ZoneMode": {"Index": i, "Mode": zconf["mode"]}})
            send_command(ip, {"ZoneSetpoint": {"Index": i, "Setpoint": zconf["temp"]}})
        elif profile.get("close_others", True):
            send_command(ip, {"ZoneMode": {"Index": i, "Mode": ZONE_MODES["close"]}})
        _time.sleep(0.2)

    mode = mode_label(profile.get("mode", "?"))
    fan = fan_label(profile.get("fan", "?"))
    print(f"Profile '{name}' applied (mode={mode}, fan={fan}, temp={fmt_temp(profile.get('temp', 0))})")


def cmd_profile_set(args):
    """Create or update a profile from flags without touching the AC."""
    name = args.name
    if not name:
        print("Profile name required.", file=sys.stderr)
        sys.exit(1)

    profiles = load_profiles()
    profile = profiles.get(name, {"close_others": True, "zones": {}})

    if args.profile_mode:
        mode_val = args.profile_mode.lower()
        if mode_val not in MODES:
            print(f"Invalid mode. Choose from: {', '.join(MODES.keys())}", file=sys.stderr)
            sys.exit(1)
        profile["mode"] = mode_val

    if args.profile_fan:
        fan_val = args.profile_fan.lower()
        if fan_val not in FAN_SPEEDS:
            print(f"Invalid fan speed. Choose from: {', '.join(FAN_SPEEDS.keys())}", file=sys.stderr)
            sys.exit(1)
        profile["fan"] = fan_val

    if args.profile_temp is not None:
        temp = float(args.profile_temp)
        if temp < 15 or temp > 30:
            print("Temperature must be between 15.0 and 30.0", file=sys.stderr)
            sys.exit(1)
        profile["temp"] = int(temp * 100)

    if args.profile_zones:
        # Format: "0:22,2:23,5:22.5" — zone_index:temp pairs
        zones = {}
        for pair in args.profile_zones.split(","):
            pair = pair.strip()
            if ":" in pair:
                idx, temp = pair.split(":", 1)
                temp_val = float(temp)
                if temp_val < 15 or temp_val > 30:
                    print(f"Zone temperature must be between 15.0 and 30.0 (got {temp_val})", file=sys.stderr)
                    sys.exit(1)
                setpoint = round(int(temp_val * 100) / 50) * 50
                zones[idx.strip()] = {"mode": ZONE_MODES["auto"], "temp": setpoint}
            else:
                # Just an index, use auto mode with system temp
                zones[pair.strip()] = {"mode": ZONE_MODES["auto"], "temp": profile.get("temp", 2300)}
        profile["zones"] = zones

    if args.no_close_others:
        profile["close_others"] = False

    if not any([args.profile_mode, args.profile_fan, args.profile_temp is not None, args.profile_zones]):
        print("No settings specified. Use --mode, --fan, --temp, --zones.", file=sys.stderr)
        sys.exit(1)

    profiles[name] = profile
    save_profiles_file(profiles)
    mode = profile.get("mode", "?")
    fan = profile.get("fan", "?")
    temp = fmt_temp(profile.get("temp", 0))
    zone_count = len(profile.get("zones", {}))
    print(f"Profile '{name}' saved (mode={mode}, fan={fan}, temp={temp}, {zone_count} zones)")


def cmd_profile_show(args):
    """Show details of a named profile."""
    name = args.name
    if not name:
        print("Profile name required.", file=sys.stderr)
        sys.exit(1)

    profiles = load_profiles()
    if name not in profiles:
        print(f"Profile '{name}' not found.", file=sys.stderr)
        sys.exit(1)

    p = profiles[name]
    print(f"Profile: {name}")
    print(f"  Mode:          {p.get('mode', '?')}")
    print(f"  Fan:           {p.get('fan', '?')}")
    print(f"  Setpoint:      {fmt_temp(p.get('temp', 0))}")
    print(f"  Close others:  {'yes' if p.get('close_others', True) else 'no'}")
    zones = p.get("zones", {})
    if zones:
        print()
        print(f"  {'Zone':<6} {'Mode':<10} {'Temp':>6}")
        print(f"  {'-' * 26}")
        for idx, z in sorted(zones.items(), key=lambda x: int(x[0])):
            zmode = ZONE_MODES_REV.get(z["mode"], str(z["mode"]))
            print(f"  {idx:<6} {zmode:<10} {fmt_temp(z['temp']):>6}")


def cmd_profile_delete(args):
    """Delete a named profile."""
    name = args.name
    if not name:
        print("Profile name required.", file=sys.stderr)
        sys.exit(1)

    profiles = load_profiles()
    if name not in profiles:
        print(f"Profile '{name}' not found.", file=sys.stderr)
        sys.exit(1)

    del profiles[name]
    save_profiles_file(profiles)
    print(f"Profile '{name}' deleted.")


NUM_SCHEDULE_SLOTS = 9


def fmt_sched_time(h, m):
    """Format schedule time, handling disabled values."""
    if h >= 31 or m >= 63:
        return "--:--"
    return f"{h:02d}:{m:02d}"


def fmt_days(days):
    """Format days dict into a short string like 'M Tu W Th F'."""
    day_map = [("M", "M"), ("Tu", "Tu"), ("W", "W"), ("Th", "Th"), ("F", "F"), ("Sa", "Sa"), ("Su", "Su")]
    active = [label for key, label in day_map if days.get(key)]
    return " ".join(active) if active else "none"


def cmd_schedules(args):
    ip = get_ip(args)
    sys_data = query_system(ip)
    num_zones = sys_data["SystemV2"]["NoOfZones"]
    print(f"{'#':<3} {'Name':<16} {'Enabled':<9} {'Start':>5} {'Stop':>5}  {'Mode':<6} {'Fan':<7} Days")
    print("-" * 75)
    for i in range(NUM_SCHEDULE_SLOTS):
        try:
            data = query_schedule(ip, i)
            s = data.get("SchedulesV2", {})
            name = s.get("Name", "").strip() or "(empty)"
            enabled = "yes" if s.get("Enabled") else "no"
            start = fmt_sched_time(s.get("StartH", 255), s.get("StartM", 255))
            stop = fmt_sched_time(s.get("StopH", 255), s.get("StopM", 255))
            mode = MODES_REV.get(s.get("Mode"), str(s.get("Mode", "?")))
            fan = FAN_REV.get(s.get("Fan"), str(s.get("Fan", "?")))
            days = fmt_days(s.get("DaysEnabled", {}))
            print(f"{i:<3} {name:<16} {enabled:<9} {start:>5} {stop:>5}  {mode:<6} {fan:<7} {days}")
        except (json.JSONDecodeError, KeyError):
            print(f"{i:<3} (unavailable)")


def cmd_schedule(args):
    ip = get_ip(args)
    index = args.slot

    if index < 0 or index >= NUM_SCHEDULE_SLOTS:
        print(f"Schedule slot must be 0-{NUM_SCHEDULE_SLOTS - 1}.", file=sys.stderr)
        sys.exit(1)

    # Handle modifications
    changed = False

    if args.name is not None:
        if len(args.name) > 15:
            print("Name must be 15 characters or less.", file=sys.stderr)
            sys.exit(1)
        send_command(ip, {"SchedName": {"Index": index, "Name": args.name}})
        print(f"Schedule {index} name set to \"{args.name}\"")
        changed = True

    if args.sched_mode:
        mode_val = args.sched_mode.lower()
        if mode_val not in MODES:
            print(f"Invalid mode. Choose from: {', '.join(MODES.keys())}", file=sys.stderr)
            sys.exit(1)
        send_command(ip, {"SchedAcMode": {"Index": index, "Mode": MODES[mode_val]}})
        print(f"Schedule {index} mode set to {mode_val}")
        changed = True

    if args.sched_fan:
        fan_val = args.sched_fan.lower()
        if fan_val not in FAN_SPEEDS:
            print(f"Invalid fan speed. Choose from: {', '.join(FAN_SPEEDS.keys())}", file=sys.stderr)
            sys.exit(1)
        send_command(ip, {"SchedAcFan": {"Index": index, "Fan": FAN_SPEEDS[fan_val]}})
        print(f"Schedule {index} fan set to {fan_val}")
        changed = True

    if args.start is not None or args.stop is not None or args.days is not None:
        settings = {"Index": index}
        if args.start is not None:
            if args.start == "off":
                settings["StartH"] = 31
                settings["StartM"] = 63
            else:
                parts = args.start.split(":")
                settings["StartH"] = int(parts[0])
                settings["StartM"] = int(parts[1])
        if args.stop is not None:
            if args.stop == "off":
                settings["StopH"] = 31
                settings["StopM"] = 63
            else:
                parts = args.stop.split(":")
                settings["StopH"] = int(parts[0])
                settings["StopM"] = int(parts[1])
        if args.days is not None:
            day_keys = ["M", "Tu", "W", "Th", "F", "Sa", "Su"]
            day_labels = {"m": "M", "tu": "Tu", "w": "W", "th": "Th", "f": "F", "sa": "Sa", "su": "Su",
                          "weekdays": None, "weekends": None, "all": None}
            days_enabled = {k: 0 for k in day_keys}
            for d in args.days.lower().split(","):
                d = d.strip()
                if d == "weekdays":
                    for k in ["M", "Tu", "W", "Th", "F"]:
                        days_enabled[k] = 1
                elif d == "weekends":
                    for k in ["Sa", "Su"]:
                        days_enabled[k] = 1
                elif d == "all":
                    days_enabled = {k: 1 for k in day_keys}
                elif d in day_labels:
                    days_enabled[day_labels[d]] = 1
                else:
                    print(f"Unknown day: {d}. Use: M,Tu,W,Th,F,Sa,Su,weekdays,weekends,all", file=sys.stderr)
                    sys.exit(1)
            settings["DaysEnabled"] = days_enabled
        send_command(ip, {"SchedSettings": settings})
        print(f"Schedule {index} timing updated")
        changed = True

    if args.enable is not None:
        val = 1 if args.enable.lower() in ("1", "yes", "true", "on") else 0
        send_command(ip, {"SchedEnable": {"Index": index, "Enabled": val}})
        print(f"Schedule {index} {'enabled' if val else 'disabled'}")
        changed = True

    if not changed:
        # Show schedule details
        try:
            data = query_schedule(ip, index)
            s = data.get("SchedulesV2", {})
        except Exception:
            print(f"Schedule {index} is unavailable.")
            return
        sys_data = query_system(ip)
        num_zones = sys_data["SystemV2"]["NoOfZones"]
        name = s.get("Name", "").strip() or "(empty)"
        enabled = "yes" if s.get("Enabled") else "no"
        start = fmt_sched_time(s.get("StartH", 255), s.get("StartM", 255))
        stop = fmt_sched_time(s.get("StopH", 255), s.get("StopM", 255))
        mode = MODES_REV.get(s.get("Mode"), str(s.get("Mode", "?")))
        fan = FAN_REV.get(s.get("Fan"), str(s.get("Fan", "?")))
        days = fmt_days(s.get("DaysEnabled", {}))

        print(f"Schedule {index}: {name}")
        print(f"  Enabled:  {enabled}")
        print(f"  Start:    {start}")
        print(f"  Stop:     {stop}")
        print(f"  Mode:     {mode}")
        print(f"  Fan:      {fan}")
        print(f"  Days:     {days}")
        print()
        zones = s.get("Zones", [])
        print(f"  {'#':<3} {'Mode':<10} {'Setpoint':>8}")
        print(f"  {'-' * 24}")
        for zi, z in enumerate(zones[:num_zones]):
            zmode = ZONE_MODES_REV.get(z.get("Mode"), str(z.get("Mode", "?")))
            print(f"  {zi:<3} {zmode:<10} {fmt_temp(z.get('Setpoint', 0)):>8}")


def cmd_run_schedule(args):
    ip = get_ip(args)
    index = args.slot
    if index < 0 or index >= NUM_SCHEDULE_SLOTS:
        print(f"Schedule slot must be 0-{NUM_SCHEDULE_SLOTS - 1}.", file=sys.stderr)
        sys.exit(1)
    # FavouriteSet uses 1-based index
    result = send_command(ip, {"FavouriteSet": index + 1})
    print(f"Schedule {index} activated ({result})")


def cmd_json(args):
    """Output raw JSON for scripting."""
    ip = get_ip(args)
    data = query_system(ip)
    s = data["SystemV2"]
    zones = []
    for i in range(s["NoOfZones"]):
        z = query_zone(ip, i)
        zones.append(z.get("ZonesV2", z))
    output = {"system": s, "zones": zones}
    print(json.dumps(output, indent=2))


def main():
    parser = argparse.ArgumentParser(
        description="iZone AC Control CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""Examples:
  izone status                    Show system and zone status
  izone system                    Show system info only
  izone zones                     List all zones
  izone on                        Turn system on
  izone off                       Turn system off
  izone mode cool                 Set to cool mode
  izone fan auto                  Set fan to auto
  izone temp 22                   Set system temperature to 22C
  izone sleep 60                  Set sleep timer to 60 minutes
  izone sleep 0                   Clear sleep timer
  izone zone 2                    Show zone 2 details
  izone zone 2 --mode auto        Set zone 2 to auto mode
  izone zone 2 --temp 23          Set zone 2 temperature to 23C
  izone zone 5 --max-air 80       Set zone 5 max airflow to 80%
  izone airquality                Show air quality readings
  izone defaults save             Save current settings as defaults
  izone defaults restore          Restore saved defaults
  izone defaults show             Show saved defaults
  izone schedules                 List all schedules
  izone schedule 2                Show schedule 2 details
  izone schedule 0 --name "Cool"  Rename schedule 0
  izone schedule 0 --mode cool --fan auto
  izone schedule 0 --start 07:30 --stop 22:00
  izone schedule 0 --days weekdays
  izone schedule 0 --enable yes   Enable a schedule
  izone run 2                     Run schedule 2 now (as a scene)
  izone profiles                  List all saved profiles
  izone profile save bedtime      Save current settings as "bedtime"
  izone profile apply bedtime     Apply "bedtime" profile
  izone profile set cool-night --mode cool --fan low --temp 23 --zones "2:22,5:23"
  izone profile show cool-night   Show profile details
  izone profile delete old-one    Delete a profile
  izone json                      Output full status as JSON
  izone discover                  Find iZone bridges on network
""",
    )
    parser.add_argument("--ip", help="Bridge IP (auto-discovered if not set)")

    sub = parser.add_subparsers(dest="command")

    sub.add_parser("discover", help="Find iZone bridges on the network")
    sub.add_parser("status", help="Show system and zone status")
    sub.add_parser("system", help="Show system info only (no zones)")
    sub.add_parser("zones", help="List all zones")
    sub.add_parser("airquality", help="Show indoor air quality readings")
    sub.add_parser("on", help="Turn system on")
    sub.add_parser("off", help="Turn system off")

    sleep_p = sub.add_parser("sleep", help="Set sleep timer (0 to clear)")
    sleep_p.add_argument("minutes", type=int, help="Minutes until auto-off (0 to clear)")
    sleep_p.add_argument("--restore", action="store_true", help="Auto-restore saved defaults when timer expires")

    mode_p = sub.add_parser("mode", help="Set operating mode")
    mode_p.add_argument("mode", choices=list(MODES.keys()))

    fan_p = sub.add_parser("fan", help="Set fan speed")
    fan_p.add_argument("speed", choices=list(FAN_SPEEDS.keys()))

    temp_p = sub.add_parser("temp", help="Set system temperature (15-30)")
    temp_p.add_argument("temp", type=float)

    zone_p = sub.add_parser("zone", help="Query or control a zone")
    zone_p.add_argument("zone", type=int, help="Zone index (0-based)")
    zone_p.add_argument("--mode", dest="zone_mode", choices=list(ZONE_MODES.keys()))
    zone_p.add_argument("--temp", dest="zone_temp", type=float, help="Zone temperature (15-30)")
    zone_p.add_argument("--max-air", type=int, help="Max airflow percentage (0-100)")
    zone_p.add_argument("--min-air", type=int, help="Min airflow percentage (0-100)")

    defaults_p = sub.add_parser("defaults", help="Save, restore, or show default settings")
    defaults_p.add_argument("action", choices=["save", "restore", "show"], help="save/restore/show defaults")

    sub.add_parser("profiles", help="List all saved profiles")

    profile_p = sub.add_parser("profile", help="Manage profiles (save/apply/set/show/delete)")
    profile_p.add_argument("action", choices=["save", "apply", "set", "show", "delete"], help="Action to perform")
    profile_p.add_argument("name", help="Profile name")
    profile_p.add_argument("--mode", dest="profile_mode", choices=list(MODES.keys()), help="AC mode")
    profile_p.add_argument("--fan", dest="profile_fan", choices=list(FAN_SPEEDS.keys()), help="Fan speed")
    profile_p.add_argument("--temp", dest="profile_temp", type=float, help="System temperature (15-30)")
    profile_p.add_argument("--zones", dest="profile_zones", help="Zone configs: idx:temp,idx:temp (e.g. 2:22,5:23)")
    profile_p.add_argument("--no-close-others", dest="no_close_others", action="store_true", help="Don't close unlisted zones when applying")

    sub.add_parser("schedules", help="List all schedules")

    sched_p = sub.add_parser("schedule", help="View or edit a schedule")
    sched_p.add_argument("slot", type=int, help="Schedule slot (0-8)")
    sched_p.add_argument("--name", help="Set schedule name (max 15 chars)")
    sched_p.add_argument("--mode", dest="sched_mode", choices=list(MODES.keys()), help="Set AC mode")
    sched_p.add_argument("--fan", dest="sched_fan", choices=list(FAN_SPEEDS.keys()), help="Set fan speed")
    sched_p.add_argument("--start", help="Start time HH:MM or 'off' to disable")
    sched_p.add_argument("--stop", help="Stop time HH:MM or 'off' to disable")
    sched_p.add_argument("--days", help="Days: M,Tu,W,Th,F,Sa,Su,weekdays,weekends,all")
    sched_p.add_argument("--enable", help="Enable/disable: yes/no")

    run_p = sub.add_parser("run", help="Run a schedule immediately (as a favourite/scene)")
    run_p.add_argument("slot", type=int, help="Schedule slot (0-8)")

    sub.add_parser("json", help="Output full status as JSON (for scripting)")

    args = parser.parse_args()

    if not args.command:
        # Default to status
        args.command = "status"
        cmd_status(args)
        return

    commands = {
        "discover": cmd_discover,
        "status": cmd_status,
        "system": cmd_system,
        "zones": cmd_zones,
        "airquality": cmd_airquality,
        "sleep": cmd_sleep,
        "on": cmd_on,
        "off": cmd_off,
        "mode": cmd_mode,
        "fan": cmd_fan,
        "temp": cmd_temp,
        "zone": cmd_zone,
        "defaults": cmd_defaults,
        "profiles": cmd_profiles,
        "profile": cmd_profile,
        "schedules": cmd_schedules,
        "schedule": cmd_schedule,
        "run": cmd_run_schedule,
        "json": cmd_json,
    }

    fn = commands.get(args.command)
    if fn:
        fn(args)
    else:
        parser.print_help()


if __name__ == "__main__":
    main()
