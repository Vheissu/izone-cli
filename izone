#!/usr/bin/env python3
"""iZone CLI - Control your iZone air conditioning from the terminal."""

import argparse
import json
import socket
import sys
import urllib.request

DISCOVERY_PORT = 12107
DISCOVERY_MSG = b"IASD"
DISCOVERY_TIMEOUT = 3
HTTP_TIMEOUT = 5

MODES = {"cool": 1, "heat": 2, "vent": 3, "dry": 4, "auto": 5}
MODES_REV = {v: k for k, v in MODES.items()}
FAN_SPEEDS = {"low": 1, "medium": 2, "high": 3, "auto": 4, "top": 5}
FAN_REV = {v: k for k, v in FAN_SPEEDS.items()}
ZONE_MODES = {"open": 1, "close": 2, "auto": 3, "override": 4, "constant": 5}
ZONE_MODES_REV = {v: k for k, v in ZONE_MODES.items()}

CONFIG_FILE = None


def discover():
    """Discover iZone bridge on the local network."""
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    sock.setsockopt(socket.SOL_SOCKET, socket.SO_BROADCAST, 1)
    sock.settimeout(DISCOVERY_TIMEOUT)
    sock.sendto(DISCOVERY_MSG, ("255.255.255.255", DISCOVERY_PORT))
    bridges = []
    try:
        while True:
            data, addr = sock.recvfrom(1024)
            text = data.decode("utf-8", errors="replace")
            parts = dict(p.split("_", 1) for p in text.split(",") if "_" in p)
            bridges.append({
                "ip": parts.get("IP", addr[0]),
                "mac": parts.get("Mac", "unknown"),
                "port": parts.get("ASPort", "12107"),
                "features": text,
            })
    except socket.timeout:
        pass
    finally:
        sock.close()
    return bridges


def post(ip, endpoint, payload):
    """Send a POST request to the iZone bridge using raw socket to avoid chunked encoding."""
    import http.client
    conn = http.client.HTTPConnection(ip, 80, timeout=HTTP_TIMEOUT)
    body = json.dumps(payload)
    conn.request("POST", endpoint, body=body, headers={"Content-Type": "application/json"})
    resp = conn.getresponse()
    raw = resp.read().decode("utf-8", errors="replace").strip()
    conn.close()
    if raw.endswith("{OK}"):
        raw = raw[:-4]
    return raw


def query_system(ip):
    """Query system settings."""
    raw = post(ip, "/iZoneRequestV2", {"iZoneV2Request": {"Type": 1, "No": 0, "No1": 0}})
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        import time
        time.sleep(0.3)
        raw = post(ip, "/iZoneRequestV2", {"iZoneV2Request": {"Type": 1, "No": 0, "No1": 0}})
        return json.loads(raw)


def query_zone(ip, index):
    """Query a specific zone."""
    raw = post(ip, "/iZoneRequestV2", {"iZoneV2Request": {"Type": 2, "No": index, "No1": 0}})
    try:
        data = json.loads(raw)
    except json.JSONDecodeError:
        # Sometimes the bridge returns OK or malformed data; retry once
        import time
        time.sleep(0.3)
        raw = post(ip, "/iZoneRequestV2", {"iZoneV2Request": {"Type": 2, "No": index, "No1": 0}})
        data = json.loads(raw)
    return data


def query_schedule(ip, index):
    """Query a specific schedule slot."""
    raw = post(ip, "/iZoneRequestV2", {"iZoneV2Request": {"Type": 3, "No": index, "No1": 0}})
    try:
        return json.loads(raw)
    except json.JSONDecodeError:
        import time
        time.sleep(0.3)
        raw = post(ip, "/iZoneRequestV2", {"iZoneV2Request": {"Type": 3, "No": index, "No1": 0}})
        return json.loads(raw)


def send_command(ip, payload):
    """Send a control command."""
    raw = post(ip, "/iZoneCommandV2", payload)
    return raw


def get_ip(args):
    """Get bridge IP from args, cache, or discovery."""
    if args.ip:
        return args.ip
    # Check cache file
    import os, time
    cache_dir = os.path.expanduser("~/.config/izone")
    cache_file = os.path.join(cache_dir, "bridge_ip")
    if os.path.exists(cache_file):
        # Use cache if less than 1 hour old
        if time.time() - os.path.getmtime(cache_file) < 3600:
            with open(cache_file) as f:
                ip = f.read().strip()
                if ip:
                    return ip
    bridges = discover()
    if not bridges:
        print("No iZone bridge found on the network.", file=sys.stderr)
        sys.exit(1)
    if len(bridges) > 1:
        print(f"Found {len(bridges)} bridges, using first: {bridges[0]['ip']}", file=sys.stderr)
    ip = bridges[0]["ip"]
    # Cache the IP
    os.makedirs(cache_dir, exist_ok=True)
    with open(cache_file, "w") as f:
        f.write(ip)
    # Small delay after UDP discovery before HTTP requests
    time.sleep(0.5)
    return ip


def fmt_temp(val):
    """Format temperature value (divide by 100)."""
    if isinstance(val, (int, float)):
        return f"{val / 100:.1f}C"
    return str(val)


def cmd_discover(args):
    bridges = discover()
    if not bridges:
        print("No iZone bridges found.")
        return
    for b in bridges:
        print(f"  IP: {b['ip']}  MAC: {b['mac']}  Features: {b['features']}")


def print_system(ip, data=None):
    """Print system-level info. Accepts optional pre-fetched data."""
    if data is None:
        data = query_system(ip)
    s = data["SystemV2"]
    on_off = "ON" if s["SysOn"] else "OFF"
    mode = MODES_REV.get(s["SysMode"], str(s["SysMode"]))
    fan = FAN_REV.get(s["SysFan"], str(s["SysFan"]))

    print(f"System:      {on_off}")
    print(f"Mode:        {mode}")
    print(f"Fan:         {fan}")
    print(f"Setpoint:    {fmt_temp(s['Setpoint'])}")
    print(f"Return Air:  {fmt_temp(s['Temp'])}")
    print(f"Supply Air:  {fmt_temp(s['Supply'])}")
    if s.get("InRh"):
        print(f"Humidity:    {s['InRh']}%")
    if s.get("IneCO2"):
        print(f"eCO2:        {s['IneCO2']} ppm")
    if s.get("InTVOC"):
        print(f"TVOC:        {s['InTVOC']} ppb")
    print(f"Zones:       {s['NoOfZones']}")
    if s.get("SleepTimer"):
        print(f"Sleep Timer: {s['SleepTimer']} min")
    if s.get("Warnings") and s["Warnings"] != "none":
        print(f"Warnings:    {s['Warnings']}")


def print_zones(ip, data=None):
    """Print zone table. Accepts optional pre-fetched system data for zone count."""
    if data is None:
        data = query_system(ip)
    num_zones = data["SystemV2"]["NoOfZones"]
    print(f"{'#':<3} {'Name':<12} {'Temp':>6} {'Set':>6} {'Mode':<10} {'Air%':>5}")
    print("-" * 48)
    for i in range(num_zones):
        zdata = query_zone(ip, i)
        z = zdata.get("ZonesV2", zdata)
        zmode = ZONE_MODES_REV.get(z["Mode"], str(z["Mode"]))
        print(f"{i:<3} {z['Name']:<12} {fmt_temp(z['Temp']):>6} {fmt_temp(z['Setpoint']):>6} {zmode:<10} {z['MaxAir']:>4}%")


def cmd_system(args):
    ip = get_ip(args)
    print_system(ip)


def cmd_zones(args):
    ip = get_ip(args)
    print_zones(ip)


def cmd_status(args):
    ip = get_ip(args)
    data = query_system(ip)
    print_system(ip, data)
    print()
    print_zones(ip, data)


def cmd_airquality(args):
    ip = get_ip(args)
