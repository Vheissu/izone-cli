        print("No air quality sensors detected.")


def schedule_restore(minutes):
    """Spawn a background process that restores defaults after the given minutes."""
    import os, subprocess
    script = get_defaults_path().replace("defaults.json", "restore_pending")
    # Write a marker file so we can cancel if needed
    os.makedirs(os.path.dirname(script), exist_ok=True)
    with open(script, "w") as f:
        f.write(str(os.getpid()))
    # Launch background restore process
    izone_path = os.path.realpath(__file__)
    subprocess.Popen(
        ["bash", "-c", f'sleep {minutes * 60} && [ -f "{script}" ] && "{sys.executable}" "{izone_path}" defaults restore && rm -f "{script}"'],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def cancel_pending_restore():
    """Cancel any pending scheduled restore."""
    import os
    script = get_defaults_path().replace("defaults.json", "restore_pending")
    if os.path.exists(script):
        os.remove(script)
        return True
    return False


def cmd_sleep(args):
    ip = get_ip(args)
    minutes = int(args.minutes)
    if minutes < 0:
        print("Minutes must be 0 or greater.", file=sys.stderr)
        sys.exit(1)
    result = send_command(ip, {"SysSleepTimer": minutes})
    if minutes == 0:
        cancel_pending_restore()
        print(f"Sleep timer cleared ({result})")
    else:
        if args.restore:
            import os
            if not os.path.exists(get_defaults_path()):
                print("No saved defaults found. Run 'izone defaults save' first.", file=sys.stderr)
                sys.exit(1)
            schedule_restore(minutes)
            print(f"Sleep timer set to {minutes} min, defaults will restore after ({result})")
        else:
            print(f"Sleep timer set to {minutes} min ({result})")


